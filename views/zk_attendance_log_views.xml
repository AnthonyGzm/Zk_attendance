<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zk_attendance_log_list" model="ir.ui.view">
        <field name="name">zk.attendance.log.list</field>
        <field name="model">zk.attendance.log</field>
        <field name="arch" type="xml">
            <list decoration-muted="not employee_id" create="0">
                <field name="device_id" string="Dispositivo"/>
                <field name="device_pin" string="ID Disp."/>
                <field name="employee_id" string="Empleado"/>
                <field name="punch_datetime" string="Fecha/Hora"/>
                <field name="punch_type" string="Tipo" widget="badge"
                       decoration-success="punch_type in ('0','3','4')"
                       decoration-warning="punch_type in ('1','2','5')"/>
                <field name="verify_type" optional="hide"/>
                <field name="processed" string="Procesado" widget="boolean_toggle"/>
                <field name="attendance_display" string="Asistencia Generada"/>
                <button name="action_force_reprocess" type="object"
                        string="Reprocesar" icon="fa-refresh" class="btn-link"/>
            </list>
        </field>
    </record>

    <record id="view_zk_attendance_log_search" model="ir.ui.view">
        <field name="name">zk.attendance.log.search</field>
        <field name="model">zk.attendance.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="device_pin"/>
                <field name="device_id"/>
                <filter name="not_processed" string="Sin Procesar" domain="[('processed','=',False)]"/>
                <filter name="unmapped" string="Sin Empleado Asignado" domain="[('employee_id','=',False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_device" string="Dispositivo" context="{'group_by':'device_id'}"/>
                    <filter name="group_employee" string="Empleado" context="{'group_by':'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_zk_attendance_log" model="ir.actions.act_window">
        <field name="name">Registros ZKTeco</field>
        <field name="res_model">zk.attendance.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_help">
                Aquí aparecen todas las marcaciones crudas recibidas de los
                equipos ZKTeco, junto con la asistencia (hr.attendance) que
                generaron una vez procesadas.
            </p>
        </field>
    </record>

</odoo>
