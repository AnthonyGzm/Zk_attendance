<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_zk_pin" model="ir.ui.view">
        <field name="name">hr.employee.form.zk.pin</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="ZKTeco" name="zkteco">
                    <group string="Reloj Checador">
                        <field name="zk_pin" placeholder="Ej: 1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
