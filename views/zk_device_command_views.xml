<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zk_device_command_list" model="ir.ui.view">
        <field name="name">zk.device.command.list</field>
        <field name="model">zk.device.command</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'" decoration-danger="state == 'error'"
                  decoration-info="state == 'sent'" decoration-muted="state == 'pending'">
                <field name="device_id"/>
                <field name="command_type"/>
                <field name="command_text"/>
                <field name="create_date" string="Creado"/>
                <field name="sent_date"/>
                <field name="done_date"/>
                <field name="return_code"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'error'"
                       decoration-info="state == 'sent'"
                       decoration-muted="state == 'pending'"/>
                <button name="action_retry" type="object" string="Reintentar" icon="fa-refresh"
                        class="btn-link" invisible="state not in ('error','sent')"/>
                <button name="action_cancel" type="object" string="Cancelar" icon="fa-times"
                        class="btn-link" invisible="state != 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_zk_device_command_form" model="ir.ui.view">
        <field name="name">zk.device.command.form</field>
        <field name="model">zk.device.command</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="pending,sent,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="device_id"/>
                            <field name="command_type"/>
                        </group>
                        <group>
                            <field name="sent_date"/>
                            <field name="done_date"/>
                            <field name="return_code"/>
                        </group>
                    </group>
                    <group string="Comando">
                        <field name="command_text" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_zk_device_command_search" model="ir.ui.view">
        <field name="name">zk.device.command.search</field>
        <field name="model">zk.device.command</field>
        <field name="arch" type="xml">
            <search>
                <field name="device_id"/>
                <field name="command_text"/>
                <filter name="pending" string="Pendientes" domain="[('state','=','pending')]"/>
                <filter name="sent" string="Enviados" domain="[('state','=','sent')]"/>
                <filter name="error" string="Con Error" domain="[('state','=','error')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_device" string="Dispositivo" context="{'group_by':'device_id'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_zk_device_command" model="ir.actions.act_window">
        <field name="name">Comandos de Dispositivos</field>
        <field name="res_model">zk.device.command</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smart_help">
                Los comandos se envían al reloj la próxima vez que este consulte
                /iclock/getrequest (modo ADMS/Push). Créalos desde la ficha del
                dispositivo o aquí manualmente.
            </p>
        </field>
    </record>

</odoo>
